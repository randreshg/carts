///===----------------------------------------------------------------------===///
/// Runtime library function attributes
///===----------------------------------------------------------------------===///
/// 
///{
/// Attribute definitions for LLVM function optimization
#ifndef ARTS_RTL_ATTRS
#define ARTS_RTL_ATTRS(Enum, FnAttrSet, RetAttrSet, ArgAttrSets)
#endif

#ifndef ARTS_ATTRS_SET
#define ARTS_ATTRS_SET(VarName, AttrSet)
#endif

#define __ARTS_RTL_ATTRS(Name, FnAttrSet, RetAttrSet, ArgAttrSets)             \
  ARTS_RTL_ATTRS(ARTSRTL_##Name, FnAttrSet, RetAttrSet, ArgAttrSets)

#define __ARTS_ATTRS_SET(VarName, AttrSet) ARTS_ATTRS_SET(VarName, AttrSet)

/// Attribute sets for ARTS runtime functions 
#define ParamAttrs(...) SmallVector<SmallVector<StringRef>>({__VA_ARGS__})

/// Define attribute sets for different function categories
__ARTS_ATTRS_SET(PureAttrs,
    SmallVector<StringRef>({"llvm.nounwind", "llvm.readnone", "llvm.nosync", 
                           "llvm.nofree", "llvm.willreturn"}))

__ARTS_ATTRS_SET(GetterAttrs,
    SmallVector<StringRef>({"llvm.nounwind", "llvm.readonly", "llvm.nosync",
                           "llvm.nofree", "llvm.willreturn"}))

__ARTS_ATTRS_SET(AllocAttrs,
    SmallVector<StringRef>({"llvm.nounwind", "llvm.nosync", "llvm.willreturn"}))

__ARTS_ATTRS_SET(ControlAttrs,
    SmallVector<StringRef>({"llvm.nounwind"}))

__ARTS_ATTRS_SET(ReadOnlyPtrAttrs,
    SmallVector<StringRef>({"llvm.readonly", "llvm.nofree", "llvm.nocapture"}))

__ARTS_ATTRS_SET(ArgPtrAttrs,
    SmallVector<StringRef>({"llvm.nocapture", "llvm.nofree"}))

__ARTS_ATTRS_SET(ReturnPtrAttrs, SmallVector<StringRef>({"llvm.noalias"}))

/// Attributes for EDT deps parameter - enables LLVM LICM to hoist pointer loads
__ARTS_ATTRS_SET(EdtDepsAttrs,
    SmallVector<StringRef>({"llvm.noalias", "llvm.readonly", "llvm.nofree", "llvm.nocapture"}))

__ARTS_ATTRS_SET(EmptyAttrs, SmallVector<StringRef>({}))

__ARTS_ATTRS_SET(SExt, SmallVector<StringRef>({"llvm.signext"}))
__ARTS_ATTRS_SET(ZExt, SmallVector<StringRef>({"llvm.zeroext"}))


#undef __ARTS_RTL_ATTRS  
#undef ARTS_RTL_ATTRS
#undef __ARTS_ATTRS_SET
#undef ARTS_ATTRS_SET
#undef ParamAttrs

///}
