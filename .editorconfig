# EditorConfig - https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cpp,h,hpp,c,td}]
indent_style = space
indent_size = 2

[*.py]
indent_style = space
indent_size = 4

[*.{md,yml,yaml,toml}]
indent_style = space
indent_size = 2

[*.mlir]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab

[*.mk]
indent_style = tab
