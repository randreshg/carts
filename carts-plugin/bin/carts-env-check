#!/bin/bash
# Quick CARTS environment validation for plugin hooks.
# Returns 0 if environment is healthy, 1 with diagnostics otherwise.

set -euo pipefail

errors=0

# Check carts command exists
if ! command -v carts &>/dev/null; then
    echo "ERROR: 'carts' command not found in PATH"
    echo "  Fix: run 'dekk carts install' to set up the environment"
    errors=$((errors + 1))
fi

# Check conda environment
if [[ -z "${CONDA_DEFAULT_ENV:-}" ]]; then
    echo "WARNING: No conda environment active"
    echo "  Fix: run 'dekk carts install' or 'conda activate carts'"
elif [[ "$CONDA_DEFAULT_ENV" != *"carts"* ]]; then
    echo "WARNING: Active conda env '$CONDA_DEFAULT_ENV' may not be the CARTS env"
fi

# Check build directory exists
if [[ -d "build" ]]; then
    if [[ ! -f "build/bin/arts-opt" ]] && [[ ! -f "build/bin/carts-opt" ]]; then
        echo "WARNING: Build directory exists but no compiler binary found"
        echo "  Fix: run 'dekk carts build'"
    fi
else
    echo "INFO: No build directory — run 'dekk carts build' to compile"
fi

# Check submodules
for sub in external/arts external/Polygeist external/llvm-project; do
    if [[ -d "$sub" ]] && [[ ! "$(ls -A "$sub" 2>/dev/null)" ]]; then
        echo "ERROR: Submodule '$sub' is empty"
        echo "  Fix: git submodule update --init --recursive"
        errors=$((errors + 1))
    fi
done

if [[ $errors -gt 0 ]]; then
    echo ""
    echo "$errors error(s) found. Run 'dekk carts install' for full setup."
    exit 1
fi

echo "CARTS environment OK"
exit 0
