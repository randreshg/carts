#!/bin/bash

# CARTS Wrapper Script
# Automatically adds necessary include paths and library paths for CARTS compilation

# Get the directory where this script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Source common print functions
source "${SCRIPT_DIR}/config/carts-print.sh"

# Determine if we're running from the installed location or the source location
if [[ "$SCRIPT_DIR" == *"/.install/carts/bin" ]]; then
    # We're running from the installed location
    # Go up 3 levels: bin -> carts -> .install -> project root
    CARTS_DIR="$(dirname "$(dirname "$(dirname "$SCRIPT_DIR")")")"
else
    # We're running from the source location
    CARTS_DIR="$(dirname "$SCRIPT_DIR")"
fi

# Define paths
INSTALL_DIR="${CARTS_DIR}/.install"
LLVM_INSTALL_DIR="${INSTALL_DIR}/llvm"
POLYGEIST_INSTALL_DIR="${INSTALL_DIR}/polygeist"
ARTS_INSTALL_DIR="${INSTALL_DIR}/arts"
CARTS_INSTALL_DIR="${INSTALL_DIR}/carts"
LLVM_INCLUDE_PATH="${LLVM_INSTALL_DIR}/lib/clang/18/include"
# Detect LLVM library path
if [[ -d "${LLVM_INSTALL_DIR}/lib/aarch64-unknown-linux-gnu" ]]; then
    LLVM_LIB_PATH="${LLVM_INSTALL_DIR}/lib/aarch64-unknown-linux-gnu"
elif [[ -d "${LLVM_INSTALL_DIR}/lib/x86_64-unknown-linux-gnu" ]]; then
    LLVM_LIB_PATH="${LLVM_INSTALL_DIR}/lib/x86_64-unknown-linux-gnu"
else
    LLVM_LIB_PATH="${LLVM_INSTALL_DIR}/lib"
fi
# macOS specific paths
MACOS_SDK_PATH="/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk"

# Platform configuration variables populated during initialization
CARTS_HOST_OS=""
CARTS_HOST_ARCH="$(uname -m 2>/dev/null || echo unknown)"
SYSTEM_INCLUDE_PATH=""
SYSTEM_CXX_INCLUDE_PATH=""
CARTS_INCLUDE_FLAGS=()
CARTS_CGEIST_SYSROOT_FLAGS=()
CARTS_CLANG_SYSROOT_FLAGS=()
CARTS_CLANG_LIBRARY_FLAGS=()
CARTS_COMPILE_LIBRARY_FLAGS=()
CARTS_CLANG_LIBRARIES=()
CARTS_COMPILE_LIBRARIES=()
CARTS_COMPILE_FLAGS=()
CARTS_LINKER_FLAGS=()

# Function to detect host configuration and populate shared flags
detect_host_config() {
    # Reset configurable arrays to ensure clean reinitialization
    CARTS_INCLUDE_FLAGS=(
        # OpenMP and clang resource headers
        "-I${LLVM_INCLUDE_PATH}"
    )

    CARTS_CLANG_LIBRARY_FLAGS=()
    CARTS_COMPILE_LIBRARY_FLAGS=()
    CARTS_CLANG_LIBRARY_FLAGS+=(
        # ARTS runtime libraries
        "-L${ARTS_INSTALL_DIR}/lib"
        # LLVM target-specific libraries
        "-L${LLVM_LIB_PATH}"
        # LLVM libraries
        "-L${LLVM_INSTALL_DIR}/lib"
    )
    CARTS_COMPILE_LIBRARY_FLAGS+=(
        # ARTS runtime libraries
        "-L${ARTS_INSTALL_DIR}/lib"
        # LLVM target-specific libraries
        "-L${LLVM_LIB_PATH}"
        # LLVM libraries
        "-L${LLVM_INSTALL_DIR}/lib"
    )

    CARTS_CLANG_LIBRARIES=(
        # C++ standard library
        "-lc++"
        # C++ ABI library
        "-lc++abi"
        # Unwind library
        "-lunwind"
    )

    CARTS_COMPILE_LIBRARIES=(
        # ARTS runtime
        "-larts"
        # OpenMP runtime
        "-lomp"
        # C++ standard library
        "-lc++"
        # C++ ABI library
        "-lc++abi"
        # Unwind library
        "-lunwind"
    )

    CARTS_COMPILE_FLAGS=(
        # Default optimization level
        "-O3"
    )

    CARTS_CGEIST_SYSROOT_FLAGS=()
    CARTS_CLANG_SYSROOT_FLAGS=()

    case "$OSTYPE" in
        darwin*)
            CARTS_HOST_OS="macos"
            SYSTEM_INCLUDE_PATH="${MACOS_SDK_PATH}/usr/include"
            SYSTEM_CXX_INCLUDE_PATH="${MACOS_SDK_PATH}/usr/include/c++/v1"
            CARTS_INCLUDE_FLAGS+=(
                # System C headers from SDK
                "-I${SYSTEM_INCLUDE_PATH}"
                # System libc++ headers from SDK
                "-I${SYSTEM_CXX_INCLUDE_PATH}"
            )
            CARTS_CGEIST_SYSROOT_FLAGS=(
                # cgeist expects --sysroot on macOS
                "--sysroot" "${MACOS_SDK_PATH}"
            )
            CARTS_CLANG_SYSROOT_FLAGS=(
                # clang uses -isysroot on macOS
                "-isysroot" "${MACOS_SDK_PATH}"
            )
            CARTS_CLANG_LIBRARY_FLAGS+=(
                # Linker runtime search path for ARTS
                "-Wl,-rpath,${ARTS_INSTALL_DIR}/lib"
            )
            CARTS_COMPILE_LIBRARY_FLAGS+=(
                # Linker runtime search path for ARTS
                "-Wl,-rpath,${ARTS_INSTALL_DIR}/lib"
                # Linker runtime search path for LLVM
                "-Wl,-rpath,${LLVM_INSTALL_DIR}/lib"
            )
            if [[ "$CARTS_HOST_ARCH" == "x86_64" ]]; then
                CARTS_COMPILE_FLAGS+=(
                    # Force non-PIE output on x86_64 builds
                    "-fno-pie"
                    "-Wl,-no_pie"
                )
            fi
            ;;
        linux-gnu*|linux-musl*|linux*)
            CARTS_HOST_OS="linux"
            SYSTEM_INCLUDE_PATH="/usr/include"
            SYSTEM_CXX_INCLUDE_PATH="/usr/include/c++/v1"
            CARTS_INCLUDE_FLAGS+=(
                # System C headers
                "-I${SYSTEM_INCLUDE_PATH}"
                # System libc++ headers
                "-I${SYSTEM_CXX_INCLUDE_PATH}"
            )
            CARTS_CLANG_LIBRARY_FLAGS+=(
                # Linker runtime search path for ARTS
                "-Wl,-rpath,${ARTS_INSTALL_DIR}/lib"
            )
            CARTS_COMPILE_LIBRARY_FLAGS+=(
                # Linker runtime search path for ARTS
                "-Wl,-rpath,${ARTS_INSTALL_DIR}/lib"
                # Linker runtime search path for LLVM
                "-Wl,-rpath,${LLVM_INSTALL_DIR}/lib"
                # System library directories
                "-L/usr/lib"
                "-L/usr/lib64"
            )
            CARTS_CLANG_LIBRARIES+=(
                # POSIX threading library
                "-lpthread"
                # POSIX realtime library
                "-lrt"
            )
            CARTS_COMPILE_LIBRARIES+=(
                # POSIX threading library
                "-lpthread"
                # POSIX realtime library
                "-lrt"
            )
            CARTS_COMPILE_FLAGS+=(
                # Force non-PIE output on Linux
                "-fno-pie"
                "-no-pie"
            )
            ;;
        msys*|cygwin*|mingw*|win32*)
            CARTS_HOST_OS="windows"
            local sdk_dir="${WindowsSdkDir:-${WINDOWSSDKDIR:-}}"
            local sdk_version="${WindowsSDKVersion:-${WINDOWSSDKVERSION:-}}"
            local vc_tools_dir="${VCToolsInstallDir:-}"
            local arch="${CARTS_WINDOWS_ARCH:-x64}"

            if [[ -z "$sdk_dir" || -z "$sdk_version" ]]; then
                carts_error "Windows SDK environment not detected. Please run inside a Visual Studio developer command prompt or set WindowsSdkDir and WindowsSDKVersion."
                exit 1
            fi

            if [[ -z "$vc_tools_dir" ]]; then
                carts_error "VCToolsInstallDir is not set. Please run inside a Visual Studio developer command prompt."
                exit 1
            fi

            sdk_dir="${sdk_dir%/}"
            sdk_version="${sdk_version%/}"
            vc_tools_dir="${vc_tools_dir%/}"

            SYSTEM_INCLUDE_PATH="${sdk_dir}/Include/${sdk_version}/ucrt"
            SYSTEM_CXX_INCLUDE_PATH="${vc_tools_dir}/include"

            if [[ ! -d "${SYSTEM_CXX_INCLUDE_PATH}" ]]; then
                carts_error "MSVC include directory not found at ${SYSTEM_CXX_INCLUDE_PATH}"
                exit 1
            fi

            if [[ ! -d "${sdk_dir}/Include/${sdk_version}" ]]; then
                carts_error "Windows SDK headers not found at ${sdk_dir}/Include/${sdk_version}"
                exit 1
            fi

            CARTS_INCLUDE_FLAGS+=(
                # Windows SDK universal CRT headers
                "-I${sdk_dir}/Include/${sdk_version}/ucrt"
                # Windows SDK shared headers
                "-I${sdk_dir}/Include/${sdk_version}/shared"
                # Windows SDK UM headers
                "-I${sdk_dir}/Include/${sdk_version}/um"
                # MSVC standard library headers
                "-I${vc_tools_dir}/include"
            )

            CARTS_CLANG_LIBRARY_FLAGS+=(
                # Windows SDK universal CRT libraries
                "-L${sdk_dir}/Lib/${sdk_version}/ucrt/${arch}"
                # Windows SDK UM libraries
                "-L${sdk_dir}/Lib/${sdk_version}/um/${arch}"
                # MSVC toolchain libraries
                "-L${vc_tools_dir}/lib/${arch}"
            )

            CARTS_COMPILE_LIBRARY_FLAGS+=(
                # Windows SDK universal CRT libraries
                "-L${sdk_dir}/Lib/${sdk_version}/ucrt/${arch}"
                # Windows SDK UM libraries
                "-L${sdk_dir}/Lib/${sdk_version}/um/${arch}"
                # MSVC toolchain libraries
                "-L${vc_tools_dir}/lib/${arch}"
            )

            if [[ ! -d "${sdk_dir}/Lib/${sdk_version}/ucrt/${arch}" || ! -d "${sdk_dir}/Lib/${sdk_version}/um/${arch}" ]]; then
                carts_error "Windows SDK libraries not found for architecture ${arch} under ${sdk_dir}/Lib/${sdk_version}"
                exit 1
            fi

            if [[ ! -d "${vc_tools_dir}/lib/${arch}" ]]; then
                carts_error "MSVC toolchain libraries not found at ${vc_tools_dir}/lib/${arch}"
                exit 1
            fi

            # Windows builds rely on MSVC runtime, so remove libc++ specific libraries
            CARTS_CLANG_LIBRARIES=()
            CARTS_COMPILE_LIBRARIES=(
                # ARTS runtime
                "-larts"
                # OpenMP runtime
                "-lomp"
            )
            CARTS_COMPILE_FLAGS+=(
                # Suppress linker banner noise on Windows
                "-Xlinker" "/NOLOGO"
            )
            ;;
        *)
            carts_error "Unsupported OS: $OSTYPE"
            exit 1
            ;;
    esac

    CARTS_INCLUDE_FLAGS+=(
        # ARTS runtime headers
        "-I${ARTS_INSTALL_DIR}/include"
        # LLVM includes
        "-I${LLVM_INSTALL_DIR}/include"
    )
}

# Function to detect and configure appropriate linker
detect_linker_config() {
    local linker_type=""
    local linker_path=""
    CARTS_LINKER_FLAGS=()
    
    # Check if we have an installed lld
    case "$CARTS_HOST_OS" in
        macos)
            if [[ -f "${LLVM_INSTALL_DIR}/bin/ld64.lld" ]]; then
                linker_type="lld"
                linker_path="${LLVM_INSTALL_DIR}/bin/ld64.lld"
            elif [[ -f "${LLVM_INSTALL_DIR}/bin/lld" ]]; then
                linker_type="lld"
                linker_path="${LLVM_INSTALL_DIR}/bin/lld"
            fi
            ;;
        linux)
            if [[ -f "${LLVM_INSTALL_DIR}/bin/ld.lld" ]]; then
                linker_type="lld"
                linker_path="${LLVM_INSTALL_DIR}/bin/ld.lld"
            elif [[ -f "${LLVM_INSTALL_DIR}/bin/lld" ]]; then
                linker_type="lld"
                linker_path="${LLVM_INSTALL_DIR}/bin/lld"
            fi
            ;;
        windows)
            if [[ -f "${LLVM_INSTALL_DIR}/bin/lld-link.exe" ]]; then
                linker_type="lld-link"
                linker_path="${LLVM_INSTALL_DIR}/bin/lld-link.exe"
            elif [[ -f "${LLVM_INSTALL_DIR}/bin/lld-link" ]]; then
                linker_type="lld-link"
                linker_path="${LLVM_INSTALL_DIR}/bin/lld-link"
            fi
            ;;
        *)
            ;;
    esac

    if [[ -n "$linker_path" ]]; then
        if [[ "$CARTS_HOST_OS" == "windows" ]]; then
            CARTS_LINKER_FLAGS+=("-fuse-ld=lld")
            CARTS_LINKER_FLAGS+=("--ld-path=${linker_path}")
        else
            CARTS_LINKER_FLAGS+=("--ld-path=${linker_path}")
        fi
    fi
    
    # Export linker configuration for use by other functions
    export CARTS_LINKER_TYPE="$linker_type"
    export CARTS_LINKER_PATH="$linker_path"
    
    if [[ -n "$CARTS_VERBOSE" && -n "$linker_type" ]]; then
        carts_debug "Detected linker: $linker_type at $linker_path"
    fi
}

