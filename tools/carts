#!/bin/bash

# CARTS CLI Wrapper
# Delegates to Python CLI implementation with cached Python path for fast startup

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_CLI="${SCRIPT_DIR}/carts_cli.py"
CACHE_FILE="${SCRIPT_DIR}/.python-cache"

# Verify Python CLI exists
if [[ ! -f "$PYTHON_CLI" ]]; then
    echo "Error: carts_cli.py not found at $PYTHON_CLI"
    exit 1
fi

# Fast path: use cached Python if valid
if [[ -f "$CACHE_FILE" ]]; then
    CACHED_PYTHON="$(cat "$CACHE_FILE")"
    if [[ -x "$CACHED_PYTHON" ]]; then
        exec "$CACHED_PYTHON" "$PYTHON_CLI" "$@"
    fi
    # Cache invalid, remove it
    rm -f "$CACHE_FILE"
fi

# Check if system python3 has dependencies
if python3 -c "import typer, rich" 2>/dev/null; then
    echo "python3" > "$CACHE_FILE"
    exec python3 "$PYTHON_CLI" "$@"
fi

# Try with poetry
if command -v poetry &> /dev/null && [[ -f "${SCRIPT_DIR}/pyproject.toml" ]]; then
    POETRY_PYTHON="$(poetry -C "$SCRIPT_DIR" env info -e 2>/dev/null)"

    if [[ -x "$POETRY_PYTHON" ]]; then
        # Cache for next time
        echo "$POETRY_PYTHON" > "$CACHE_FILE"
        exec "$POETRY_PYTHON" "$PYTHON_CLI" "$@"
    fi

    # Dependencies not installed - try to install them
    echo "Installing CARTS CLI dependencies..."
    if poetry -C "$SCRIPT_DIR" install --quiet 2>/dev/null; then
        POETRY_PYTHON="$(poetry -C "$SCRIPT_DIR" env info -e 2>/dev/null)"
        if [[ -x "$POETRY_PYTHON" ]]; then
            echo "$POETRY_PYTHON" > "$CACHE_FILE"
            exec "$POETRY_PYTHON" "$PYTHON_CLI" "$@"
        fi
    fi
fi

# Error: dependencies not available
echo "Error: Required Python dependencies not installed."
echo ""
echo "To install dependencies, run one of:"
echo "  pip install typer rich"
echo "  cd ${SCRIPT_DIR} && poetry install"
exit 1
