# Function to run cgeist with automatic include paths
run_cgeist() {
    local input_file="$1"
    shift
    
    if [[ ! -f "$input_file" ]]; then
        carts_error "Input file '$input_file' not found"
        exit 1
    fi
    
    # Use shared include and sysroot configuration populated during host detection
    local include_paths=("${CARTS_INCLUDE_FLAGS[@]}")
    local extra_cflags=("${CARTS_CGEIST_SYSROOT_FLAGS[@]}")
    
    if [[ -n "$CARTS_VERBOSE" ]]; then
        carts_debug "Running cgeist with include paths:"
        printf "  %s\n" "${include_paths[@]}"
        if [[ ${#extra_cflags[@]} -gt 0 ]]; then
            carts_debug "Additional cgeist flags: ${extra_cflags[*]}"
        fi
        carts_debug "Command: ${POLYGEIST_INSTALL_DIR}/bin/cgeist ${include_paths[*]} ${extra_cflags[*]} $input_file $*"
    fi
    
    "${POLYGEIST_INSTALL_DIR}/bin/cgeist" "${include_paths[@]}" "${extra_cflags[@]}" "$input_file" "$@"
}


# Function to run clang with automatic include and library paths
run_clang() {
    local input_file="$1"
    shift

    if [[ ! -f "$input_file" ]]; then
        carts_error "Input file '$input_file' not found"
        exit 1
    fi

    # Use installed LLVM clang
    local clang_path="${LLVM_INSTALL_DIR}/bin/clang"
    if [[ ! -f "$clang_path" ]]; then
        carts_error "LLVM clang not found at $clang_path"
        carts_info "Please ensure LLVM is properly installed"
        exit 1
    fi

    # Use shared include, library, sysroot, and linker configuration
    local include_paths=("${CARTS_INCLUDE_FLAGS[@]}")
    local sysroot_flags=("${CARTS_CLANG_SYSROOT_FLAGS[@]}")
    local library_paths=("${CARTS_CLANG_LIBRARY_FLAGS[@]}")
    local linker_flags=("${CARTS_LINKER_FLAGS[@]}")
    local libraries=("${CARTS_CLANG_LIBRARIES[@]}")

    if [[ -n "$CARTS_VERBOSE" ]]; then
        carts_debug "Running LLVM clang with:"
        carts_debug "Include paths: ${include_paths[*]}"
        if [[ ${#sysroot_flags[@]} -gt 0 ]]; then
            carts_debug "Sysroot flags: ${sysroot_flags[*]}"
        fi
        carts_debug "Library and linker flags: ${library_paths[*]} ${linker_flags[*]}"
        carts_debug "Libraries: ${libraries[*]}"
        carts_debug "Command: ${clang_path} ${include_paths[*]} ${sysroot_flags[*]} ${library_paths[*]} ${linker_flags[*]} -fopenmp $input_file ${libraries[*]} $*"
    fi

    "${clang_path}" "${include_paths[@]}" "${sysroot_flags[@]}" "${library_paths[@]}" "${linker_flags[@]}" -fopenmp "$input_file" "${libraries[@]}" "$@"
}


# Function to run carts-run (the C++ executable)
run_run() {
    if [[ -n "$CARTS_VERBOSE" ]]; then
        carts_debug "Running carts-run: ${CARTS_INSTALL_DIR}/bin/carts-run $*"
    fi

    "${CARTS_INSTALL_DIR}/bin/carts-run" "$@"
}

# Function to run mlir-translate
run_mlir_translate() {
    if [[ -n "$CARTS_VERBOSE" ]]; then
        carts_debug "Running mlir-translate: ${LLVM_INSTALL_DIR}/bin/mlir-translate $*"
    fi
    
    "${LLVM_INSTALL_DIR}/bin/mlir-translate" "$@"
}

# Function to compile with ARTS runtime
run_compile() {
    local input_file="$1"
    shift
    
    # Handle help flag
    if [[ "$input_file" == "--help" || "$input_file" == "-h" ]]; then
        carts_info "Compile options:"
        carts_info "  <input_file>        Input LLVM IR file (.ll)"
        carts_info "  -o <output>         Output executable name"
        carts_info "  -g                  Embed DWARF debug symbols in the final binary"
        carts_info "  --help, -h          Show this help"
        carts_info ""
        carts_info "Examples:"
        carts_info "  carts compile simple.ll -o simple"
        carts_info "  carts compile simple.ll -o simple -g"
        exit 0
    fi
    
    if [[ ! -f "$input_file" ]]; then
        carts_error "Input file '$input_file' not found"
        exit 1
    fi
    
    # Use installed LLVM clang for ARTS operations
    local clang_path="${LLVM_INSTALL_DIR}/bin/clang"
    if [[ ! -f "$clang_path" ]]; then
        carts_error "LLVM clang not found at $clang_path"
        carts_info "Please ensure LLVM is properly installed"
        exit 1
    fi
    
    # Reuse host-specific configuration collected earlier
    local library_paths=("${CARTS_COMPILE_LIBRARY_FLAGS[@]}")
    local libraries=("${CARTS_COMPILE_LIBRARIES[@]}")
    local sysroot_flags=("${CARTS_CLANG_SYSROOT_FLAGS[@]}")
    local linker_flags=("${CARTS_LINKER_FLAGS[@]}")
    
    # Build compile flags and force non-PIE output when required so function
    # pointers remain stable across nodes (required for remote EDT execution).
    local compile_flags=("${CARTS_COMPILE_FLAGS[@]}")

    if [[ -n "$CARTS_VERBOSE" ]]; then
        carts_debug "Running LLVM clang with compile flags:"
        printf "  %s\n" "${compile_flags[@]}"
        if [[ ${#sysroot_flags[@]} -gt 0 ]]; then
            carts_debug "Sysroot flags:"
            printf "  %s\n" "${sysroot_flags[@]}"
        fi
        carts_debug "Library and linker flags:"
        local combined_flags=("${library_paths[@]}" "${linker_flags[@]}")
        printf "  %s\n" "${combined_flags[@]}"
        carts_debug "Libraries:"
        printf "  %s\n" "${libraries[@]}"
        if [[ -n "$CARTS_LINKER_PATH" ]]; then
            carts_debug "Using linker: $CARTS_LINKER_PATH"
        fi
        carts_debug "Command: $clang_path ${compile_flags[*]} ${sysroot_flags[*]} ${library_paths[*]} ${linker_flags[*]} ${libraries[*]} $input_file $*"
    fi
    
    "$clang_path" "${compile_flags[@]}" "${sysroot_flags[@]}" "${library_paths[@]}" "${linker_flags[@]}" "${libraries[@]}" "$input_file" "$@"
}

# Function to run benchmark tool
run_benchmark() {
    local benchmark_script="${CARTS_DIR}/tools/benchmark/carts-benchmark.py"
    if [[ ! -f "$benchmark_script" ]]; then
        carts_error "Benchmark script not found at $benchmark_script"
        exit 1
    fi

    if [[ -n "$CARTS_VERBOSE" ]]; then
        carts_debug "Running benchmark: python3 $benchmark_script $*"
    fi

    python3 "$benchmark_script" "$@"
}


# Function to run visualizer tool
run_visualize() {
    local server_dir="${CARTS_DIR}/tools/visualizer/server"
    # Detect --serve flag
    local serve_mode=false
    local args=("$@")
    for a in "$@"; do
        if [[ "$a" == "--serve" ]]; then
            serve_mode=true
            break
        fi
    done

    # If first arg is a .mlir file and --serve given, export JSON to server dir and launch UI
    if [[ -f "$1" && "$1" == *.mlir && "$serve_mode" == true ]]; then
        shift # remove mlir path from args for exporter capture
        local mlir_file="$1" # actually after shift we lost it; restore
    fi

    if [[ -f "$1" && "$1" == *.mlir ]]; then
        local mlir_file="$1"; shift
        local out_json="${server_dir}/graph.json"
        if [[ -n "$CARTS_VERBOSE" ]]; then
            carts_debug "Exporting JSON: ${CARTS_INSTALL_DIR}/bin/carts-visualizer $mlir_file --json -o $out_json $*"
        fi
        "${CARTS_INSTALL_DIR}/bin/carts-visualizer" "$mlir_file" --json -o "$out_json" "$@"
        if [[ "$serve_mode" == true ]]; then
            if [[ -n "$CARTS_VERBOSE" ]]; then
                carts_debug "Launching visualizer UI server: python3 ${server_dir}/app.py"
            fi
            python3 "${server_dir}/app.py"
        fi
    else
        if [[ -n "$CARTS_VERBOSE" ]]; then
            carts_debug "Launching visualizer UI server: python3 ${server_dir}/app.py $*"
        fi
        python3 "${server_dir}/app.py" "$@"
    fi
}

# Function to build CARTS project using system clang
run_build() {
    carts_header "CARTS Build"
    carts_print "Building CARTS project using system clang"
    
    # Check if we're in the right directory
    if [[ ! -f "${CARTS_DIR}/Makefile" ]]; then
        carts_error "Makefile not found. Are you in the CARTS project root?"
        exit 1
    fi
    
    # Parse build options
    local clean_build=false
    local build_target="build"
    local docker_build=false
    local arts_debug_level="none"
    local arts_build_type="Release"
    local arts_introspection=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            "--clean"|"-c")
                clean_build=true
                shift
                ;;
            "--arts"|"-a")
                build_target="arts"
                shift
                ;;
            "--introspection"|"-i")
                arts_introspection=true
                shift
                ;;
            "--info")
                arts_debug_level="info"
                shift
                ;;
            "--debug")
                arts_debug_level="debug"
                arts_build_type="Debug"
                shift
                ;;
            "--polygeist"|"-p")
                build_target="polygeist"
                shift
                ;;
            "--llvm"|"-l")
                build_target="llvm"
                shift
                ;;
            "--docker"|"-d")
                docker_build=true
                shift
                ;;
            "--help"|"-h")
                carts_print "Build options:"
                carts_print "  (default)       Build CARTS project (make build)"
                carts_print "  --clean, -c     Clean build (make clean && make build)"
                carts_print "  --arts, -a      Build only ARTS components"
                carts_print "  --introspection, -i  Enable ARTS introspection and counters (use with --arts)"
                carts_print "  --info           Enable info-level debugging (use with --arts)"
                carts_print "  --debug          Enable debug build with debug+info logging (use with --arts)"
                carts_print "  --polygeist, -p Build only Polygeist (make polygeist)"
                carts_print "  --llvm, -l      Build only LLVM (make llvm)"
                carts_print "  --docker, -d    Build Docker image (docker/docker-build.sh)"
                carts_print "  --help, -h      Show this help"
                exit 0
                ;;
            *)
                carts_error "Unknown build option: $1"
                carts_print "Use --help for available options"
                exit 1
                ;;
        esac
    done
    
    # Change to project directory
    cd "${CARTS_DIR}"
    
    if [[ "$clean_build" == "true" ]]; then
        if [[ -n "$CARTS_VERBOSE" ]]; then
            carts_debug "Cleaning build..."
        fi
        if [[ "$docker_build" == "true" ]]; then
            local docker_dir="${CARTS_DIR}/docker"
            if [[ ! -d "$docker_dir" ]]; then
                carts_error "Docker directory not found at $docker_dir"
                exit 1
            fi
            if [[ -n "$CARTS_VERBOSE" ]]; then
                carts_debug "Running Docker clean script: $docker_dir/docker-clean.sh"
            fi
            (cd "$docker_dir" && ./docker-clean.sh)
        else
            make clean
        fi
    fi

    # Build make command with variables
    local make_vars=""
    if [[ "$arts_introspection" == "true" ]]; then
        make_vars="$make_vars ARTS_USE_COUNTERS=ON ARTS_USE_METRICS=ON"
    fi

    # Handle debug level flags
    case "$arts_debug_level" in
        "info")
            make_vars="$make_vars ARTS_INFO_ENABLED=ON"
            ;;
        "debug")
            make_vars="$make_vars ARTS_DEBUG_ENABLED=ON ARTS_INFO_ENABLED=ON"
            ;;
    esac

    if [[ "$arts_build_type" != "Release" ]]; then
        make_vars="$make_vars ARTS_BUILD_TYPE=$arts_build_type"
    fi

    if [[ -n "$CARTS_VERBOSE" ]]; then
        if [[ "$docker_build" == "true" ]]; then
            carts_debug "Running Docker build script: ${CARTS_DIR}/docker/docker-build.sh"
        else
            carts_debug "Running: make $make_vars $build_target"
        fi
    fi

    if [[ "$docker_build" == "true" ]]; then
        local docker_dir="${CARTS_DIR}/docker"
        if [[ ! -d "$docker_dir" ]]; then
            carts_error "Docker directory not found at $docker_dir"
            exit 1
        fi
        (cd "$docker_dir" && ./docker-build.sh)
    else
        if [[ -n "$make_vars" ]]; then
            make $make_vars "$build_target"
        else
            make "$build_target"
        fi
    fi
    
    if [[ $? -eq 0 ]]; then
        carts_header "Build Complete"
        carts_success "CARTS build completed successfully!"
        if [[ "$docker_build" == "true" ]]; then
            carts_success "Docker build completed"
        fi
    else
        carts_header "Build Failed"
        carts_error "CARTS build failed!"
        exit 1
    fi
}

