#!/bin/bash
# CARTS CLI wrapper — bootstraps the Python venv if needed, then runs carts_cli.py.
#
# Preferred: install sniff globally and run directly:
#   pip install git+https://github.com/randreshg/sniff.git
#   sniff tools/carts_cli.py install
#
# This wrapper provides the same bootstrap for users without sniff.
set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CARTS_DIR="$(dirname "$SCRIPT_DIR")"
VENV_DIR="$SCRIPT_DIR/.venv"

# ---------------------------------------------------------------------------
# Bootstrap: create the venv automatically on first run
# ---------------------------------------------------------------------------
if [ ! -d "$VENV_DIR" ] || [ ! -x "$VENV_DIR/bin/python" ]; then
    echo "First run — setting up Python environment..."

    if command -v poetry &>/dev/null; then
        POETRY_VIRTUALENVS_IN_PROJECT=true poetry -C "$SCRIPT_DIR" install --no-root --quiet 2>&1 \
            | grep -v "^$" || true
    else
        # Fallback: create venv with pip (no Poetry needed)
        PYTHON_CMD=""
        for candidate in python3.13 python3.12 python3.11 python3.10 python3; do
            if command -v "$candidate" &>/dev/null; then
                PYTHON_CMD="$candidate"
                break
            fi
        done

        if [ -z "$PYTHON_CMD" ]; then
            echo "Error: No Python >= 3.10 found. Install python3 and try again." >&2
            exit 1
        fi

        "$PYTHON_CMD" -m venv "$VENV_DIR"
        "$VENV_DIR/bin/pip" install --quiet typer "rich>=13.7" openpyxl \
            "sniff[cli] @ git+https://github.com/randreshg/sniff.git@main"
    fi

    if [ ! -x "$VENV_DIR/bin/python" ]; then
        echo "Error: Failed to create Python environment at $VENV_DIR" >&2
        echo "Try manually: poetry -C $SCRIPT_DIR install --no-root" >&2
        exit 1
    fi

    echo "Done."
    echo ""
fi

# ---------------------------------------------------------------------------
# Run carts_cli.py with the venv Python
# ---------------------------------------------------------------------------
exec "$VENV_DIR/bin/python" "$SCRIPT_DIR/carts_cli.py" "$@"
