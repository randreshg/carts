# Function to run CARTS test suite
run_check() {
    carts_info "Running CARTS test suite..."
    
    # Check if tests directory exists
    local tests_dir="${CARTS_DIR}/tests"
    if [[ ! -d "$tests_dir" ]]; then
        carts_error "Tests directory not found at $tests_dir"
        carts_info "The test infrastructure may not be set up yet."
        exit 1
    fi
    
    # Check if llvm-lit exists
    local llvm_lit="${LLVM_INSTALL_DIR}/bin/llvm-lit"
    if [[ ! -f "$llvm_lit" ]]; then
        carts_error "llvm-lit not found at $llvm_lit"
        carts_info "Please ensure LLVM is properly installed by running 'carts build'"
        exit 1
    fi
    
    # Parse check options
    local test_suite="all"
    local extra_args=()
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            "--suite")
                if [[ -n "$2" && "$2" != -* ]]; then
                    test_suite="$2"
                    shift 2
                else
                    carts_error "--suite requires a value (e.g., 'mlir', 'all')"
                    exit 1
                fi
                ;;
            "--help"|"-h")
                carts_info "Check options:"
                carts_info "  (default)           Run all CARTS tests"
                carts_info "  --suite arts        Run only ARTS tests"
                carts_info "  --suite all         Run all test suites (default)"
                carts_info "  -v                  Verbose output from llvm-lit"
                carts_info "  --help, -h          Show this help"
                exit 0
                ;;
            *)
                # Pass remaining arguments to llvm-lit
                extra_args+=("$1")
                shift
                ;;
        esac
    done
    
    # Determine test path based on suite
    local test_path
    case "$test_suite" in
        "all")
            test_path="$tests_dir"
            ;;
        "arts")
            test_path="$tests_dir/arts"
            ;;
        *)
            carts_error "Unknown test suite '$test_suite'"
            carts_info "Available suites: all, arts"
            exit 1
            ;;
    esac
    
    # Ensure test path exists
    if [[ ! -d "$test_path" ]]; then
        carts_error "Test path not found: $test_path"
        exit 1
    fi
    
    carts_info "Test suite: $test_suite"
    carts_info "Test path: $test_path"
    carts_line
    
    if [[ -n "$CARTS_VERBOSE" ]]; then
        carts_debug "Running: $llvm_lit -v $test_path ${extra_args[*]}"
        carts_line
    fi
    
    # Run the tests
    "$llvm_lit" -v "$test_path" "${extra_args[@]}"
    local exit_code=$?
    
    carts_line
    if [[ $exit_code -eq 0 ]]; then
        carts_success "CARTS test suite completed successfully!"
    else
        carts_error "CARTS test suite failed with exit code $exit_code"
    fi
    
    return $exit_code
}

# Function to execute complete pipeline
run_execute() {
    local input_file="$1"
    shift
    
    if [[ ! -f "$input_file" ]]; then
        carts_error "Input file '$input_file' not found"
        exit 1
    fi
    
    # Extract base name without extension
    local base_name="${input_file%.*}"
    local extension="${input_file##*.}"
    
    # Validate input file type
    if [[ "$extension" != "cpp" && "$extension" != "c" ]]; then
        carts_error "Input file must be .cpp or .c"
        exit 1
    fi
    
    # Parse execute options
    local execute_args=()
    local run_args=()
    local compile_args=()
    local parsing_run_args=false
    local parsing_compile_args=false
    local debug_mode=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            "--run-args")
                parsing_run_args=true
                parsing_compile_args=false
                shift
                ;;
            "--compile-args")
                parsing_run_args=false
                parsing_compile_args=true
                shift
                ;;
            "-g")
                debug_mode=true
                shift
                ;;
            *)
                if [[ "$parsing_run_args" == "true" ]]; then
                    run_args+=("$1")
                elif [[ "$parsing_compile_args" == "true" ]]; then
                    compile_args+=("$1")
                else
                    execute_args+=("$1")
                fi
                shift
                ;;
        esac
    done
    
    carts_header "CARTS Execution"
    carts_info "Running CARTS for: $input_file"
    carts_line
    
    # Step 1: C++ to MLIR
    carts_step "Converting C++ to MLIR"

    # Determine standard flag based on file extension
    local std_flag=""
    if [[ "$extension" == "cpp" ]]; then
        std_flag="-std=c++17"
    elif [[ "$extension" == "c" ]]; then
        std_flag="-std=c17"
    fi
    
    # Build cgeist flags
    local cgeist_flags=("$std_flag" "-fopenmp" "-O0" "-S")

    if [[ -n "$CARTS_VERBOSE" ]]; then
        carts_debug "Running: carts cgeist $input_file ${cgeist_flags[*]} > ${base_name}.mlir"
    fi
    
    # Temporarily disable verbose output for file generation
    local original_verbose="$CARTS_VERBOSE"
    unset CARTS_VERBOSE
    
    if ! carts cgeist "$input_file" "${cgeist_flags[@]}" > "${base_name}.mlir"; then
        carts_error "Failed to convert C++ to MLIR"
        exit 1
    fi
    
    # Step 2: MLIR to LLVM IR with ARTS transformations
    carts_step "Applying ARTS transformations and converting to LLVM IR"
    
    # Build the carts run command with additional args
    local run_cmd_args=("${base_name}.mlir" "--O3" "--emit-llvm")
    if [[ "$debug_mode" == "true" ]]; then
        run_cmd_args+=("-g")
    fi
    
    # Add any additional run arguments
    if [[ ${#run_args[@]} -gt 0 ]]; then
        run_cmd_args+=("${run_args[@]}")
    fi
    
    if [[ -n "$original_verbose" ]]; then
        carts_debug "Running: carts run ${run_cmd_args[*]} > ${base_name}-arts.ll"
    fi
    
    if ! carts run "${run_cmd_args[@]}" > "${base_name}-arts.ll"; then
        carts_error "Failed to apply ARTS transformations"
        exit 1
    fi
    
    # Restore verbose output
    if [[ -n "$original_verbose" ]]; then
        export CARTS_VERBOSE="$original_verbose"
    fi
    
    # Step 3: Compile to executable
    carts_step "Compiling to executable"
    
    # Build the compile command with additional args
    local compile_cmd_args=("${base_name}-arts.ll" "-o" "${base_name}")
    if [[ "$debug_mode" == "true" ]]; then
        compile_cmd_args+=("-g")
    fi
    if [[ ${#compile_args[@]} -gt 0 ]]; then
        compile_cmd_args+=("${compile_args[@]}")
    fi
    
    if [[ -n "$CARTS_VERBOSE" ]]; then
        carts_debug "Running: carts compile ${compile_cmd_args[*]}"
    fi
    
    if ! carts compile "${compile_cmd_args[@]}"; then
        carts_error "Failed to compile to executable"
        exit 1
    fi
    
    carts_line
    carts_success "Generated executable: ${base_name}"
    carts_line
    carts_info "Intermediate files:"
    carts_print "  MLIR: ${base_name}.mlir"
    carts_print "  LLVM IR: ${base_name}-arts.ll"
    carts_print "  Executable: ${base_name}"
    carts_line
    carts_info "To clean intermediate files, run: carts clean"
    carts_header "CARTS Complete"
}

# Main script logic
main() {
    # Set LLVM_SYMBOLIZER_PATH for better stack traces on crashes
    export LLVM_SYMBOLIZER_PATH="${LLVM_INSTALL_DIR}/bin/llvm-symbolizer"

    # Detect host configuration and set shared flags
    detect_host_config

    # Detect and configure appropriate linker
    detect_linker_config
    
    # Check if we have a command
    if [[ $# -eq 0 ]]; then
        show_usage
        exit 1
    fi
    
    local command="$1"
    shift
    
    case "$command" in
        "build")
            run_build "$@"
            ;;
        "cgeist")
            run_cgeist "$@"
            ;;
        "clang")
            run_clang "$@"
            ;;
        "run")
            run_run "$@"
            ;;
        "mlir-translate")
            run_mlir_translate "$@"
            ;;
        "compile")
            run_compile "$@"
            ;;
        "benchmark")
            run_benchmark "$@"
            ;;
        "ui")
            # Start the external ARTS UI backend and frontend (dev helpers)
            carts_info "Launching ARTS UI backend on :8090"
            (cd "${CARTS_DIR}/external/ArtsUI/backend" && python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8090) &
            carts_info "Launching ARTS UI frontend on :5174"
            (cd "${CARTS_DIR}/external/ArtsUI/frontend" && npm run dev) &
            carts_info "Open http://localhost:5174"
            ;;
        "visualize")
            run_visualize "$@"
            ;;
        "setup")
            run_setup "$@"
            ;;
        "clean")
            run_clean "$@"
            ;;
        "check")
            run_check "$@"
            ;;
        "execute")
            run_execute "$@"
            ;;
        "docker")
            run_docker "$@"
            ;;
        "help"|"-h"|"--help")
            show_usage
            ;;
        *)
            carts_error "Unknown command: $command"
            show_usage
            exit 1
            ;;
    esac
}

# Run main function with all arguments
main "$@" 
