# Function to clean local generated files
run_local_clean() {
    carts_info "Cleaning generated files in current directory..."

    # Files to remove
    local files_to_remove=(
        "*.mlir"
        "*.ll"
        "*.o"
        "*.so"
        "*.dylib"
        "*.a"
        "*.exe"
        "DbGraph_*.dot"
        "*.log"
        "*.tmp"
        ".artsPrintLock"
    )

    # Directories to remove
    local dirs_to_remove=(
        "build"
        "cmake-build-*"
        ".cache"
        "introspection"
    )

    local removed_count=0

    # Remove files
    for pattern in "${files_to_remove[@]}"; do
        for file in $pattern; do
            if [[ -f "$file" ]]; then
                if [[ -n "$CARTS_VERBOSE" ]]; then
                    carts_debug "Removing file: $file"
                fi
                rm -f "$file"
                ((removed_count++))
            fi
        done
    done

    # Remove directories
    for pattern in "${dirs_to_remove[@]}"; do
        for dir in $pattern; do
            if [[ -d "$dir" ]]; then
                if [[ -n "$CARTS_VERBOSE" ]]; then
                    carts_debug "Removing directory: $dir"
                fi
                rm -rf "$dir"
                ((removed_count++))
            fi
        done
    done

    # Remove executables (but preserve source files)
    for file in *; do
        if [[ -f "$file" && -x "$file" && ! "$file" =~ \.(cpp|c|h|hpp|py|sh|md|txt|cfg|yaml|json)$ ]]; then
            if [[ -n "$CARTS_VERBOSE" ]]; then
                carts_debug "Removing executable: $file"
            fi
            rm -f "$file"
            ((removed_count++))
        fi
    done

    if [[ $removed_count -eq 0 ]]; then
        carts_info "No generated files found to clean"
    else
        carts_success "Cleaned $removed_count files/directories"
    fi
}

