#!/bin/bash

# CARTS CLI wrapper
# Uses the single shared Poetry environment for tools/

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHON_CLI="${SCRIPT_DIR}/carts_cli.py"
SHARED_PYTHON=""

has_required_python_deps() {
    local python_bin="$1"
    "$python_bin" -c "import typer, rich, openpyxl" 2>/dev/null
}

get_poetry_python() {
    poetry -C "$SCRIPT_DIR" env info -e 2>/dev/null || true
}

ensure_shared_env() {
    if ! command -v poetry >/dev/null 2>&1; then
        echo "Error: Poetry is required to bootstrap CARTS Python environment."
        echo "Install Poetry and run: poetry -C ${SCRIPT_DIR} install --no-root"
        return 1
    fi

    if [[ ! -f "${SCRIPT_DIR}/pyproject.toml" ]]; then
        echo "Error: pyproject.toml not found at ${SCRIPT_DIR}/pyproject.toml"
        return 1
    fi

    local poetry_python
    poetry_python="$(get_poetry_python)"
    if [[ -n "$poetry_python" ]] && [[ -x "$poetry_python" ]] && has_required_python_deps "$poetry_python"; then
        SHARED_PYTHON="$poetry_python"
        return 0
    fi

    echo "Bootstrapping CARTS Python environment ..."
    POETRY_VIRTUALENVS_IN_PROJECT=true poetry -C "$SCRIPT_DIR" install --no-root

    poetry_python="$(get_poetry_python)"
    if [[ -z "$poetry_python" ]] || [[ ! -x "$poetry_python" ]] || ! has_required_python_deps "$poetry_python"; then
        echo "Error: failed to prepare CARTS Python environment with required dependencies."
        return 1
    fi
    SHARED_PYTHON="$poetry_python"
}

if [[ ! -f "$PYTHON_CLI" ]]; then
    echo "Error: carts_cli.py not found at $PYTHON_CLI"
    exit 1
fi

ensure_shared_env
exec "$SHARED_PYTHON" "$PYTHON_CLI" "$@"
